{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MeshCoreBotConfig",
  "type": "object",
  "properties": {
    "connection": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["auto", "ble", "serial", "tcp"]
        },
        "address": {
          "type": "string"
        },
        "port": {
          "type": "string"
        },
        "baudrate": {
          "type": "integer",
          "minimum": 110,
          "maximum": 921600
        },
        "host": {
          "type": "string"
        },
        "tcpPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "required": ["type", "address", "port", "baudrate", "host", "tcpPort"]
    },
    "core": {
      "type": "object",
      "properties": {
        "timeSyncInterval": {
          "type": "string"
        },
        "shutdownTimeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 60000
        },
        "ipcPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "timezone": {
          "type": "string"
        },
        "latitude": {
          "type": "number",
          "minimum": -90.0,
          "maximum": 90.0
        },
        "longitude": {
          "type": "number",
          "minimum": -180.0,
          "maximum": 180.0
        }
      },
      "required": ["timeSyncInterval", "shutdownTimeoutMs"]
    },
    "modules": {
      "type": "object"
    }
  },
  "required": ["connection", "core", "modules"]
}
